{
    "$schema": "/outpost/docs/schemas/theme.schema.json",
    "name": "Skeleton",
    "version": "1.0.0",
    "author": "Port City Pixel",
    "description": "Developer reference theme. Heavily commented, demonstrates every Outpost template tag. Duplicate this to start building your own theme.",
    "screenshot": "",
    "managed": true,
    "customizer": {
        "sections": [
            {
                "id": "colors",
                "label": "Colors",
                "fields": [
                    { "key": "color-accent", "label": "Accent Color", "type": "color", "default": "#3B82F6", "var": "--color-accent" },
                    { "key": "color-text", "label": "Text Color", "type": "color", "default": "#1F2937", "var": "--color-text" },
                    { "key": "color-bg", "label": "Background", "type": "color", "default": "#FFFFFF", "var": "--color-bg" },
                    { "key": "color-muted", "label": "Muted Text", "type": "color", "default": "#6B7280", "var": "--color-muted" }
                ]
            },
            {
                "id": "typography",
                "label": "Typography",
                "fields": [
                    { "key": "font-heading", "label": "Heading Font", "type": "font", "default": "Inter", "var": "--font-heading" },
                    { "key": "font-body", "label": "Body Font", "type": "font", "default": "Inter", "var": "--font-body" }
                ]
            },
            {
                "id": "identity",
                "label": "Site Identity",
                "fields": [
                    { "key": "logo", "label": "Site Logo", "type": "image" },
                    { "key": "favicon", "label": "Favicon", "type": "image" }
                ]
            }
        ]
    }
}
