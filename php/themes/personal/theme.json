{
    "$schema": "/outpost/docs/schemas/theme.schema.json",
    "name": "Personal",
    "version": "2.0.0",
    "author": "Port City Pixel",
    "description": "Reference personal blog theme. Demonstrates every Outpost template tag: collection loops, single items, folder loops, menu loops with dropdowns, pagination, global fields, meta tags, conditionals, and the admin check.",
    "screenshot": "",
    "managed": true,
    "customizer": {
        "sections": [
            {
                "id": "colors",
                "label": "Colors",
                "fields": [
                    { "key": "color-accent", "label": "Accent Color", "type": "color", "default": "#14B8A6", "var": "--color-accent" },
                    { "key": "color-accent-hover", "label": "Accent Hover", "type": "color", "default": "#0D9488", "var": "--color-accent-hover" },
                    { "key": "color-ink", "label": "Text Color", "type": "color", "default": "#27272A", "var": "--color-ink" },
                    { "key": "color-body", "label": "Background", "type": "color", "default": "#FAFAFA", "var": "--color-body" },
                    { "key": "color-paper", "label": "Surface Color", "type": "color", "default": "#FFFFFF", "var": "--color-paper" },
                    { "key": "color-muted", "label": "Muted Text", "type": "color", "default": "#52525B", "var": "--color-muted" }
                ]
            },
            {
                "id": "typography",
                "label": "Typography",
                "fields": [
                    { "key": "font-heading", "label": "Heading Font", "type": "font", "default": "Inter", "var": "--font-display" },
                    { "key": "font-body", "label": "Body Font", "type": "font", "default": "Inter", "var": "--font-sans" }
                ]
            },
            {
                "id": "identity",
                "label": "Site Identity",
                "fields": [
                    { "key": "logo", "label": "Site Logo", "type": "image" },
                    { "key": "favicon", "label": "Favicon", "type": "image" }
                ]
            }
        ]
    }
}
